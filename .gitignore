# Unity 에디터 생성물
unity/Library/
unity/Logs/
unity/UserSettings/
unity/Temp/
unity/obj/
unity/Assets/Screenshots/
unity/Assets/Screenshots.meta
unity/Captures/

# 일회성 측정 스크립트 — 리포트에 표를 남기고 스크립트는 커밋하지 않는다 (구 web/tools/)
engine/tools/scratch-*.ts

# Unity Asset Store 에셋 — 공개 저장소에 원본 커밋 금지 (worldbuilding §8).
# 코드는 Resources.Load 실패 시 코드 생성 FX로 폴백하므로 클론/CI에서도 동작한다.
unity/Assets/EffectExamples/
unity/Assets/EffectExamples.meta
unity/Assets/Resources/Fx/
unity/Assets/Resources/Fx.meta
unity/Assets/AssetHunts!/
unity/Assets/AssetHunts!.meta

# 외부 에셋 킷 원본 다운로드(Kenney CC0) — 실제 사용분만 Resources에 커밋한다
resources/kenney_tower-defense-kit/

# SparkSet 파티클 팩 원본 — 라이선스가 독립 에셋 재배포를 금지한다.
# 게임에 통합된 사용분(phaser/public/assets/fx/)만 커밋한다.
resources/SparkSet Particle Pack Vol 1/

# Asset Store 원본 다운로드(Cainos 등) — 원본 커밋 금지, 사용분(크롭)만 커밋한다
resources/downloads/

# Tiled 에디터 세션 상태(UI 상태) — 소스가 아니다. .tiled-project는 커밋한다
*.tiled-session

# 세션 임시 파일
tmp/

# 의존성 — vitest 캐시(results.json)가 실수로 커밋된 이력이 있다
node_modules/

# 루트에서 잘못 생성된 Vite 캐시(소스 프로젝트가 아님)
web-svelte/

# 게임 런 로그(JSONL) — /logs viewer가 내려받은 실행 산출물. 소스가 아니다.
logs/

# Wrangler 로컬 상태 — 로컬 D1 sqlite 파일과 캐시. 소스가 아니다.
.wrangler/
