{
  "name": "g-td-phaser",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "vite build",
    "check": "svelte-check --tsconfig ./tsconfig.json",
    "test": "vitest run",
    "preview": "vite preview",
    "deploy": "vite build && node -e \"require('fs').writeFileSync('.svelte-kit/cloudflare/.assetsignore','_worker.js\\n_routes.json\\n')\" && wrangler deploy",
    "db:apply:local": "wrangler d1 migrations apply game-td-run-logs --local",
    "db:apply:remote": "wrangler d1 migrations apply game-td-run-logs --remote",
    "prepare": "svelte-kit sync"
  },
  "dependencies": {
    "phaser": "3.90.0",
    "svelte": "^5.56.7"
  },
  "devDependencies": {
    "@cloudflare/workers-types": "^5.20260723.1",
    "@sveltejs/adapter-cloudflare": "^7.2.9",
    "@sveltejs/kit": "^2.70.1",
    "@sveltejs/vite-plugin-svelte": "^5.1.1",
    "@tailwindcss/vite": "^4.3.3",
    "@types/node": "^26.1.1",
    "daisyui": "^5.7.0",
    "svelte-check": "^4.1.0",
    "svelte-grab": "^1.4.2",
    "tailwindcss": "^4.3.3",
    "typescript": "^5.6.0",
    "vite": "^6.0.0",
    "vitest": "^3.0.0",
    "wrangler": "^4.113.0"
  }
}
